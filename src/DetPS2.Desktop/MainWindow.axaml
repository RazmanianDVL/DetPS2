<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DetPS2.Desktop.MainWindow"
        Title="DetPS2Sharp — Deterministic PS2 Emulator"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        DragDrop.AllowDrop="True">

    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto,Auto,*,Auto">
        <!-- Menu Bar -->
        <Menu Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Background="{DynamicResource MenuBackground}">
            <MenuItem Header="_File">
                <MenuItem Header="Load _BIOS..." Click="OnLoadBiosClick" HotKey="Ctrl+B" />
                <MenuItem Header="Load _ELF..." Click="OnLoadElfClick" HotKey="Ctrl+E" />
                <Separator />
                <MenuItem Header="_Save State..." Click="OnSaveStateClick" HotKey="Ctrl+S" />
                <MenuItem Header="_Load State..." Click="OnLoadStateClick" HotKey="Ctrl+L" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExitClick" HotKey="Alt+F4" />
            </MenuItem>

            <MenuItem Header="_Emulation">
                <MenuItem Header="_Run" Click="OnRunClick" HotKey="F5" />
                <MenuItem Header="_Pause" Click="OnPauseClick" HotKey="F6" />
                <MenuItem Header="_Reset" Click="OnResetClick" HotKey="F9" />
                <Separator />
                <MenuItem Header="Step _1M cycles" Click="OnStepClick" HotKey="F10" />
                <MenuItem Header="Render _Test Scene" Click="OnTestDrawClick" HotKey="F11" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Reset _Framebuffer View" Click="OnResetFramebufferViewClick" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About DetPS2Sharp..." Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="8,4">
            <Button Content="Load BIOS" Click="OnLoadBiosClick" ToolTip.Tip="Ctrl+B" />
            <Button Content="Load ELF" Click="OnLoadElfClick" ToolTip.Tip="Ctrl+E" />
            <Separator Width="1" Margin="4,2" />
            <Button Content="▶ Run" Click="OnRunClick" ToolTip.Tip="F5" />
            <Button Content="⏸ Pause" Click="OnPauseClick" ToolTip.Tip="F6" />
            <Button Content="⟲ Reset" Click="OnResetClick" ToolTip.Tip="F9" />
            <Button Content="Step" Click="OnStepClick" ToolTip.Tip="F10" />
            <Separator Width="1" Margin="4,2" />
            <Button Content="🎨 Test Scene" Click="OnTestDrawClick" ToolTip.Tip="F11" />
            <Button Content="💾 Save State" Click="OnSaveStateClick" ToolTip.Tip="Ctrl+S" />
            <Button Content="📂 Load State" Click="OnLoadStateClick" ToolTip.Tip="Ctrl+L" />

            <Separator Width="1" Margin="6,2" />

            <!-- Emulation Speed Control -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox x:Name="SpeedCombo" Width="110" SelectedIndex="1" SelectionChanged="OnSpeedChanged">
                    <ComboBoxItem Content="Slow" />
                    <ComboBoxItem Content="Normal" />
                    <ComboBoxItem Content="Fast" />
                    <ComboBoxItem Content="Unlimited" />
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Main Display Area -->
        <Border Grid.Column="0" Grid.Row="2" x:Name="DisplayBorder"
                BorderBrush="#444" BorderThickness="1" Margin="8" Background="#0a0a12"
                CornerRadius="4"
                DragDrop.AllowDrop="True">
            <Image x:Name="FramebufferImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="4" />
        </Border>

        <!-- Right Sidebar: System Status Panel -->
        <Border Grid.Column="1" Grid.Row="2" Width="240" Margin="0,8,8,8"
                Background="#1a1a22" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
            <StackPanel Margin="12" Spacing="10">
                <TextBlock Text="SYSTEM STATUS" FontWeight="Bold" FontSize="14" Foreground="#aaa" />
                <Separator />

                <StackPanel Spacing="4">
                    <TextBlock Text="Status" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="SidebarStatus" Text="Ready" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Master Cycles" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="SidebarCycles" Text="0" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Emulation Speed" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="SidebarSpeed" Text="Normal" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Updates / sec" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="SidebarFps" Text="~60" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>

                <Separator Margin="0,8" />

                <TextBlock Text="Drag files here or use toolbar" 
                           FontSize="11" Foreground="#666" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3" 
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center" />
                <TextBlock x:Name="CyclesText" Text="Master Cycles: 0" VerticalAlignment="Center" />
                <TextBlock x:Name="FpsText" Text="~60 updates/sec" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>

</Window>